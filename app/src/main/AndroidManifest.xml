<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".HudProApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HudPro">

        <!-- Management app entry point -->
        <activity
            android:name=".manager.ManagerActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Map viewer / OpenTracks dashboard receiver -->
        <activity
            android:name=".viewer.MapViewerActivity"
            android:exported="true"
            android:label="@string/viewer_title"
            android:launchMode="singleTask">
            <!-- NOTE: action string must match APIConstants.ACTION_DASHBOARD -->
            <intent-filter>
                <action android:name="Intent.OpenTracks-Dashboard" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge"
            xmlns:tools="http://schemas.android.com/tools" />

    </application>

</manifest>
